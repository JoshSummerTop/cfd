{
  "name": "@codefromdesign/cfd",
  "version": "0.6.0",
  "description": "CLI + MCP server for CodeFromDesign — sync Figma-to-code pipeline results with Claude Code",
  "type": "module",
  "bin": {
    "cfd": "./dist/cli.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "esbuild src/cli.ts --bundle --platform=node --target=node18 --format=esm --outfile=dist/cli.js --minify",
    "prepublishOnly": "npm run build",
    "build:check": "tsc --noEmit",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@types/node": "^20.0.0",
    "esbuild": "^0.27.4",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "zod": "^4.3.6"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "codefromdesign",
    "figma",
    "mcp",
    "claude-code"
  ],
  "license": "MIT"
}
